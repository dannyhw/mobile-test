{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    },
    "moduleResolution": "bundler"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    ".rnstorybook/**/*.ts",
    ".rnstorybook/**/*.tsx",
    "vitest.config.mts",
    "node_modules/mobile-test/matchers.d.ts"
  ]
}
